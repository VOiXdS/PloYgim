local Boxes = {}
local function GetBox(player)
    if Boxes[player] then return Boxes[player] end
    local b = Drawing.new("Square"); b.Thickness = 1; b.Filled = false; b.Transparency = 1; b.Visible = false
    Boxes[player] = b; return b
end

local FOV_Circle = Drawing.new("Circle"); FOV_Circle.Thickness = 1; FOV_Circle.NumSides = 60
local hooking = false; local hookTarget = nil

-- [[ ЦИКЛ ]]
RunService.RenderStepped:Connect(function()
    local char = lp.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChild("Humanoid")
    local mouseLoc = UIS:GetMouseLocation()

    if UIS:IsKeyDown(Enum.KeyCode[STATE.Bind_Menu]) and tick() - lastMenuPress > 0.3 then
        lastMenuPress = tick(); STATE.Visible = not STATE.Visible; main.Visible = STATE.Visible
    end

    if STATE.Visible then
        STATE.AccentColor = Color3.fromRGB(STATE.ColorR, STATE.ColorG, STATE.ColorB)
        local t = Themes[STATE.CurrentTheme] or {Grad1 = Color3.new(0,0,0), Grad2 = Color3.new(0.1,0.1,0.1)}
        mainStroke.Color = STATE.AccentColor; mainGrad.Color = ColorSequence.new(t.Grad1, t.Grad2)
        
        for k, v in pairs(toggles) do 
            if v and v.Parent then
                v.BackgroundTransparency = STATE[k] and 0 or 1
                v.BackgroundColor3 = STATE.AccentColor 
            end
        end
        for _, v in ipairs(sg:GetDescendants()) do 
            if v.Name == "Fill" or v.Name == "Accent" then v.BackgroundColor3 = STATE.AccentColor end 
        end
    end

    if STATE.HookEnabled and hooking and hookTarget and hrp then
        hookForce.Parent = hrp; local dir = (hookTarget - hrp.Position).Unit
        if (hookTarget - hrp.Position).Magnitude > 7 then hookForce.Velocity = dir * STATE.HookSpeed else hooking = false; hookForce.Parent = nil end
    else hookForce.Parent = nil end

    if STATE.BhopEnabled and hum and hrp then
        if UIS:IsKeyDown(Enum.KeyCode.Space) then
            hum.Jump = true; local moveDir = hum.MoveDirection
            if hum.FloorMaterial == Enum.Material.Air then
                lastGrounded = false
                if moveDir.Magnitude > 0 then hrp.Velocity = v3_new(moveDir.X * STATE.BhopPower, hrp.Velocity.Y, moveDir.Z * STATE.BhopPower) end
            else
                if not lastGrounded then STATE.BhopPower = m_clamp(STATE.BhopPower + 3, 16, STATE.BhopMax); lastGrounded = true end
                if moveDir.Magnitude > 0 then hrp.Velocity = v3_new(moveDir.X * STATE.BhopPower, hrp.Velocity.Y, moveDir.Z * STATE.BhopPower) end
            end
        else STATE.BhopPower = 16; lastGrounded = true end
    end

    local aim_target, hud_p, shortest = nil, nil, STATE.AimFOV
    local players = Players:GetPlayers()
    
    for i = 1, #players do
        local p = players[i]
        if p ~= lp and p.Character and not IsFriend(p.UserId) then
            local pchar = p.Character
            local root = pchar:FindFirstChild("HumanoidRootPart")
            local head = pchar:FindFirstChild("Head")
            local phum = pchar:FindFirstChild("Humanoid")
            
            if root and phum and phum.Health > 0 then
                local pos, on = Camera:WorldToViewportPoint(root.Position)
                local box = GetBox(p)
                if STATE.BoxEsp and on then
                    local sizeX = 2500 / pos.Z; local sizeY = 3800 / pos.Z
                    box.Size = Vector2.new(sizeX, sizeY); box.Position = Vector2.new(pos.X - sizeX / 2, pos.Y - sizeY / 2); box.Color = STATE.AccentColor; box.Visible = true
                else box.Visible = false end
                
                if STATE.ChamsEsp then
                    local h = pchar:FindFirstChild("PloY_Highlight") or Instance.new("Highlight", pchar)
                    h.FillColor = STATE.AccentColor; h.Enabled = true; h.Name = "PloY_Highlight"
                elseif pchar:FindFirstChild("PloY_Highlight") then pchar.PloY_Highlight.Enabled = false end

                if head and not IsTeammate(p) then
                    local hPos, hOn = Camera:WorldToViewportPoint(head.Position)
                    if hOn then
                        local d = (Vector2.new(hPos.X, hPos.Y) - mouseLoc).Magnitude
                        if d < shortest and IsVisible(head) then 
                            shortest = d
                            if m_random(1, 100) <= STATE.HeadRatio then aim_target = head else aim_target = root end
                            hud_p = p 
                        end
                    end
                end
            elseif Boxes[p] then Boxes[p].Visible = false end
        end
    end
    
    if tick() - targetUpdateTick > 0.05 then targetUpdateTick = tick(); STATE.TPBehindTarget = hud_p; STATE.LockedPart = aim_target end

    if STATE.TargetHUDEnabled and STATE.TPBehindTarget and STATE.TPBehindTarget.Character then
        local thum = STATE.TPBehindTarget.Character:FindFirstChild("Humanoid")
        if thum then
            targetHud.Visible = true; targetName.Text = STATE.TPBehindTarget.Name
            targetHPFill.Size = UDim2.new(m_clamp(thum.Health/thum.MaxHealth, 0, 1), 0, 1, 0)
        else targetHud.Visible = false end
    else targetHud.Visible = false end

    if hrp then
        if STATE.AimEnabled and STATE.SkyTarget and STATE.LockedPart and (UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) or UIS:IsKeyDown(Enum.KeyCode.Backquote)) then
            hrp.CFrame = STATE.LockedPart.CFrame * cf_new(0, 15, 0) * cf_angles(m_rad(-90), 0, 0)
            hrp.Velocity = v3_new(0,0,0)
        end

        if STATE.XKillEnabled and UIS:IsKeyDown(Enum.KeyCode.X) and UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
            if not originalPos then originalPos = hrp.CFrame end
            if STATE.LockedPart then
                if tick() - xKillTick > 0.03 then 
                    hrp.CFrame = cf_new(hrp.Position.X, 100000, hrp.Position.Z)
                    xKillTick = tick() + 0.5
                else
                    hrp.CFrame = STATE.LockedPart.CFrame
                    mouse1click()
                end
            else
                hrp.CFrame = cf_new(hrp.Position.X, 100000, hrp.Position.Z)
                hrp.Velocity = v3_new(0,0,0)
            end
        end

        if STATE.AimEnabled and STATE.LockedPart and not STATE.SkyTarget then
            if UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) or UIS:IsKeyDown(Enum.KeyCode.Backquote) then
                if m_random(1, 100) <= STATE.HitChance then
                    local p = Camera:WorldToViewportPoint(STATE.LockedPart.Position)
                    mousemoverel((p.X - mouseLoc.X)/STATE.AimSmooth, (p.Y - mouseLoc.Y)/STATE.AimSmooth)
                end
            end
        end

        if STATE.SpinBot then bAV.Parent = hrp; bAV.AngularVelocity = v3_new(0, STATE.SpinSpeed, 0) else bAV.Parent = nil end
        if STATE.Noclip and char then
            for _, v in ipairs(char:GetChildren()) do 
                if v:IsA("BasePart") and v.CanCollide then v.CanCollide = false end 
            end
        end

        if STATE.FlyEnabled then
            local fDir = v3_new(0,0,0)
            local camCF = Camera.CFrame
            if UIS:IsKeyDown(Enum.KeyCode.W) then fDir += camCF.LookVector end
            if UIS:IsKeyDown(Enum.KeyCode.S) then fDir -= camCF.LookVector end
            hrp.Velocity = fDir * STATE.FlySpeed
        elseif STATE.SpeedEnabled and hum and hum.MoveDirection.Magnitude > 0 then
            hrp.CFrame += (hum.MoveDirection * STATE.SpeedPower / 5)
        end
    end
    
    FOV_Circle.Visible = (STATE.AimEnabled and STATE.Visible); FOV_Circle.Radius = STATE.AimFOV; FOV_Circle.Position = mouseLoc; FOV_Circle.Color = STATE.AccentColor
end)

UIS.InputBegan:Connect(function(i, g)
    if not g and i.KeyCode == Enum.KeyCode.E and STATE.TPBehindEnabled and STATE.TPBehindTarget and lp.Character then
        local tHRP = STATE.TPBehindTarget.Character:FindFirstChild("HumanoidRootPart")
        if tHRP then lp.Character.HumanoidRootPart.CFrame = tHRP.CFrame * cf_new(0,0,3) end
    end
    if not g and i.KeyCode == Enum.KeyCode.Q and STATE.HookEnabled then 
        local unitRay = Camera:ViewportPointToRay(UIS:GetMouseLocation().X, UIS:GetMouseLocation().Y)
        local res = workspace:Raycast(unitRay.Origin, unitRay.Direction * 5000)
        if res then hookTarget = res.Position; hooking = true end
    end
end)

UIS.InputEnded:Connect(function(i, g) if i.KeyCode == Enum.KeyCode.Q then hooking = false end end)

LoadConfig()
pages.Aim.Visible = true
